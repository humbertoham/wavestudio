{
  "name": "wavestudio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:clean": "node scripts/clean-next-dev.mjs && next dev --turbopack",
    "dev:no-turbo": "node scripts/clean-next-dev.mjs && next dev",
    "booking:dedupe:dry": "node scripts/reconcile-active-booking-duplicates.mjs",
    "booking:dedupe:apply": "node scripts/reconcile-active-booking-duplicates.mjs --execute",
    "wellhub:repair": "node scripts/repair-wellhub-renewal-state.mjs",
    "wellhub:require-plan-confirmation": "node scripts/require-wellhub-plan-confirmation.mjs",
    "wellhub:reset-confirmations": "node scripts/require-wellhub-plan-confirmation.mjs",
    "wellhub:verify-confirmation-app": "node scripts/verify-wellhub-confirmation-app.mjs",
    "challenge:verify-point-editing-app": "node scripts/verify-challenge-point-editing-app.mjs",
    "env:check": "node scripts/check-env.mjs",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:status:dev": "node scripts/branch-db.mjs dev status",
    "db:status:uat": "node scripts/branch-db.mjs uat status",
    "db:migrate:dev": "node scripts/branch-db.mjs dev migrate",
    "db:migrate:uat": "node scripts/branch-db.mjs uat migrate",
    "db:seed:dev-uat": "node prisma/seed.dev-uat.mjs",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "build": "prisma generate && next build",
    "start": "next start"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^1.3.8",
    "framer-motion": "^12.23.12",
    "jose": "^6.1.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.9.0",
    "next": "16.0.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.5.0",
    "resend": "^6.9.1",
    "swr": "^2.3.6",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "prisma": "^6.16.2",
    "tailwindcss": "^4.1.12",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
