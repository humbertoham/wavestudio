// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/**
 * =========================
 * Enums
 * =========================
 */
enum Role {
  USER
  COACH
  ADMIN
}

enum Affiliation {
  NONE
  WELLHUB
  TOTALPASS
}

enum WellhubPlan {
  GOLD_PLUS
  PLATINUM
  DIAMOND
  DIAMOND_PLUS
}

enum BookingStatus {
  ACTIVE
  CANCELED
}

enum TokenReason {
  PURCHASE_CREDIT // alta inicial al comprar paquete
  BOOKING_DEBIT // consumo por reserva
  CANCEL_REFUND // reembolso por cancelación válida
  ADMIN_ADJUST // ajustes manuales
  CORPORATE_MONTHLY
  ADMIN_WELLHUB_PLAN_CHANGE
  USER_WELLHUB_PLAN_CONFIRMATION
}

enum WellhubPlanConfirmationStatus {
  PENDING
  COMPLETED
}

enum PackHighlight {
  POPULAR
  BEST
}

enum PaymentProvider {
  MERCADOPAGO
  ADMIN
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CANCELED
}

enum CheckoutStatus {
  CREATED
  OPEN
  EXPIRED
  COMPLETED
  CANCELED
}

enum ChallengePointReason {
  ATTENDANCE_AWARD
  ATTENDANCE_REVERSAL
}

/**
 * =========================
 * Modelos base
 * =========================
 */
model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  passwordHash     String
  emailVerified    DateTime?
  role             Role      @default(USER)
  bookingBlocked   Boolean   @default(false)
  bookingBlockedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // relaciones
  bookings                      Booking[]
  packs                         PackPurchase[]
  tokenLedger                   TokenLedger[]
  waitlists                     Waitlist[]
  payments                      Payment[]
  checkoutLinks                 CheckoutLink[]
  bookingBlockLogs              BookingBlockLog[]
  challengeTotals               ChallengeUserTotal[]
  challengeAwards               ChallengeBookingAward[]
  challengePointLedger          ChallengePointLedger[]     @relation("ChallengePointUser")
  challengePointActions         ChallengePointLedger[]     @relation("ChallengePointActor")
  challengePointAdjustments     ChallengePointAdjustment[] @relation("ChallengePointAdjustmentUser")
  challengePointAdjustmentsMade ChallengePointAdjustment[] @relation("ChallengePointAdjustmentActor")
  challengeActivations          Challenge[]                @relation("ChallengeActivatedBy")
  challengeDeactivations        Challenge[]                @relation("ChallengeDeactivatedBy")

  // password reset
  passwordResetTokens PasswordResetToken[]

  // perfil
  dateOfBirth            DateTime?
  phone                  String?      @db.VarChar(20)
  emergencyPhone         String?      @db.VarChar(20)
  affiliation            Affiliation  @default(NONE)
  wellhubPlan            WellhubPlan?
  affiliationConfirmedAt DateTime?

  // Stateless JWT revocation and forced WellHub plan reconfirmation.
  authVersion                        Int                       @default(0)
  wellhubPlanConfirmationRequired    Boolean                   @default(false)
  wellhubPlanConfirmationRequestedAt DateTime?
  wellhubPlanConfirmedAt             DateTime?
  wellhubPlanConfirmationCampaign    String?
  wellhubPlanConfirmations           WellhubPlanConfirmation[]
}

model WellhubPlanConfirmation {
  id                         String                        @id @default(cuid())
  campaign                   String
  user                       User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                     String
  status                     WellhubPlanConfirmationStatus @default(PENDING)
  requestedAt                DateTime
  confirmedAt                DateTime?
  previousPlan               WellhubPlan?
  selectedPlan               WellhubPlan?
  previousMonthlyEntitlement Int?
  newMonthlyEntitlement      Int?
  creditDeltaApplied         Int?
  resultingBalance           Int?
  source                     String
  ledgerEntryId              String?
  idempotencyKey             String                        @unique
  createdAt                  DateTime                      @default(now())
  updatedAt                  DateTime                      @updatedAt

  @@unique([campaign, userId])
  @@index([campaign, status, requestedAt])
  @@index([userId, requestedAt])
}

model Instructor {
  id        String   @id @default(cuid())
  name      String
  bio       String?
  createdAt DateTime @default(now())

  isVisible Boolean @default(true)

  classes Class[]
}

/**
 * =========================
 * Clases y Reservas
 * =========================
 */
model Class {
  id           String     @id @default(cuid())
  title        String
  focus        String
  date         DateTime
  durationMin  Int
  capacity     Int
  creditCost   Int        @default(1) // costo en tokens por reservar
  instructor   Instructor @relation(fields: [instructorId], references: [id])
  instructorId String
  bookings     Booking[]

  // extras opcionales útiles
  location        String?
  isCanceled      Boolean    @default(false)
  // Calendar deletion is distinct from a business cancellation. Rows with
  // history are archived with this timestamp so their audit relations survive.
  deletedAt       DateTime?
  cancelBeforeMin Int? // minutos antes del inicio para permitir reembolso de token
  waitlist        Waitlist[]

  // Eligibility is snapshotted only when the class is created while active.
  challenge                  Challenge?              @relation(fields: [challengeId], references: [id])
  challengeId                String?
  challengePoints            Int?
  challengeEligibleAt        DateTime?
  challengeActivationVersion Int?
  challengeAwards            ChallengeBookingAward[]
  challengePointLedger       ChallengePointLedger[]

  @@index([date])
  @@index([deletedAt, date])
  @@index([challengeId])
}

model Booking {
  id String @id @default(cuid())

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  guestName String? // invitado

  class   Class  @relation(fields: [classId], references: [id])
  classId String

  status    BookingStatus @default(ACTIVE)
  createdAt DateTime      @default(now())

  quantity Int @default(1)

  // 🔥 ASISTENCIA
  attended Boolean @default(false)

  packPurchase   PackPurchase? @relation(fields: [packPurchaseId], references: [id])
  packPurchaseId String?

  canceledAt  DateTime?
  refundToken Boolean?

  ledgerEntries        TokenLedger[]
  challengeAwards      ChallengeBookingAward[]
  challengePointLedger ChallengePointLedger[]

  // IMPORTANT:
  // A PostgreSQL CHECK constraint is created manually in SQL migration
  // to enforce quantity >= 1.
  //
  // A PostgreSQL partial unique index is created manually in SQL migration
  // to enforce one ACTIVE user booking per class:
  // ("userId", "classId") WHERE "status" = 'ACTIVE' AND "userId" IS NOT NULL
  @@index([classId])
  @@index([userId])
}

/**
 * =========================
 * Challenge
 * =========================
 */
model Challenge {
  id                String    @id @default(cuid())
  key               String    @unique
  name              String
  isActive          Boolean   @default(false)
  activationVersion Int       @default(0)
  activatedAt       DateTime?
  deactivatedAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  activatedBy     User?   @relation("ChallengeActivatedBy", fields: [activatedById], references: [id], onDelete: SetNull)
  activatedById   String?
  deactivatedBy   User?   @relation("ChallengeDeactivatedBy", fields: [deactivatedById], references: [id], onDelete: SetNull)
  deactivatedById String?

  classes          Class[]
  userTotals       ChallengeUserTotal[]
  awards           ChallengeBookingAward[]
  pointLedger      ChallengePointLedger[]
  pointAdjustments ChallengePointAdjustment[]

  @@index([isActive])
}

model ChallengeUserTotal {
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  challengeId String
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  points      Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@id([challengeId, userId])
  @@index([challengeId, points])
  @@index([userId, challengeId])
}

// Mutable per-booking state supports safe reversal and re-award cycles. The
// immutable audit history lives in ChallengePointLedger.
model ChallengeBookingAward {
  id             String    @id @default(cuid())
  challenge      Challenge @relation(fields: [challengeId], references: [id])
  challengeId    String
  booking        Booking   @relation(fields: [bookingId], references: [id])
  bookingId      String
  class          Class     @relation(fields: [classId], references: [id])
  classId        String
  user           User      @relation(fields: [userId], references: [id])
  userId         String
  pointsSnapshot Int
  cycle          Int       @default(1)
  isAwarded      Boolean   @default(true)
  awardedAt      DateTime  @default(now())
  reversedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([challengeId, bookingId])
  @@index([challengeId, userId])
  @@index([classId])
}

model ChallengePointLedger {
  id             String               @id @default(cuid())
  challenge      Challenge            @relation(fields: [challengeId], references: [id])
  challengeId    String
  booking        Booking              @relation(fields: [bookingId], references: [id])
  bookingId      String
  class          Class                @relation(fields: [classId], references: [id])
  classId        String
  user           User                 @relation("ChallengePointUser", fields: [userId], references: [id])
  userId         String
  actor          User?                @relation("ChallengePointActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorUserId    String?
  delta          Int
  reason         ChallengePointReason
  pointsSnapshot Int
  cycle          Int
  idempotencyKey String               @unique
  metadata       Json?
  createdAt      DateTime             @default(now())

  @@unique([challengeId, bookingId, reason, cycle])
  @@index([challengeId, userId, createdAt])
  @@index([challengeId, classId])
  @@index([bookingId])
}

// Immutable audit trail for explicit admin overrides of the current aggregate.
// Attendance history remains in ChallengePointLedger and is never rewritten.
model ChallengePointAdjustment {
  id                String    @id @default(cuid())
  challenge         Challenge @relation(fields: [challengeId], references: [id], onDelete: Restrict)
  challengeId       String
  user              User      @relation("ChallengePointAdjustmentUser", fields: [userId], references: [id], onDelete: Restrict)
  userId            String
  actor             User?     @relation("ChallengePointAdjustmentActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorUserId       String?
  activationVersion Int
  previousPoints    Int
  newPoints         Int
  createdAt         DateTime  @default(now())

  @@index([challengeId, userId, createdAt])
  @@index([actorUserId, createdAt])
}

/**
 * =========================
 * Paquetes y Compras
 * =========================
 */
model Pack {
  id           String         @id @default(cuid())
  name         String
  classes      Int
  price        Int // MXN
  validityDays Int
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  purchases    PackPurchase[]

  isVisible Boolean @default(true)

  oncePerUser Boolean @default(false)

  // marketing/UI
  classesLabel String? // ej. "5 clases"
  highlight    PackHighlight?
  description  Json? // ej. string[] (bullets) o estructura rica
  CheckoutLink CheckoutLink[]
}

model PackPurchase {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String
  pack   Pack   @relation(fields: [packId], references: [id])
  packId String

  classesLeft Int
  expiresAt   DateTime
  pausedDays  Int       @default(0)
  pausedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // relaciones derivadas
  bookings      Booking[]
  ledgerEntries TokenLedger[]

  // Relación con Payment (1–1, opcional)
  payment   Payment? @relation("PaymentToPackPurchase", fields: [paymentId], references: [id])
  paymentId String?  @unique // <- necesario para 1–1

  @@index([userId, expiresAt])
}

model BookingBlockLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  blocked   Boolean
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/**
 * =========================
 * Ledger de tokens
 * =========================
 */
model TokenLedger {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  packPurchase   PackPurchase? @relation(fields: [packPurchaseId], references: [id])
  packPurchaseId String?

  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId String?

  delta          Int
  reason         TokenReason
  idempotencyKey String?     @unique
  metadata       Json?
  createdAt      DateTime    @default(now())

  @@index([userId, packPurchaseId])
  @@index([userId, reason, createdAt])
  @@index([bookingId])
}

/**
 * =========================
 * Lista de espera
 * =========================
 */
model Waitlist {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  class     Class    @relation(fields: [classId], references: [id])
  classId   String
  position  Int
  createdAt DateTime @default(now())

  @@unique([userId, classId])
  @@index([classId, position])
}

/**
 * =========================
 * Pagos / Enlaces / Webhooks
 * =========================
 */
model Payment {
  id       String          @id @default(cuid())
  provider PaymentProvider
  status   PaymentStatus   @default(PENDING)
  amount   Int // en MXN
  currency String          @default("MXN")

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  // Mercadopago specifics
  mpPreferenceId String? // preference_id
  mpPaymentId    String? // payment.id (cuando exista)
  mpInitPoint    String? // init_point para redirigir
  mpExternalRef  String? // external_reference
  mpPayerEmail   String?
  mpRaw          Json? // snapshot del payload (preference/payment)

  // Relación 1–1 con PackPurchase (opcional)
  packPurchase PackPurchase? @relation("PaymentToPackPurchase")

  // Relación 1–1 con CheckoutLink (opcional)
  checkoutLink CheckoutLink? @relation("PaymentToCheckout")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, status])
  @@index([mpPreferenceId])
  @@index([mpPaymentId])
}

model CheckoutLink {
  id     String         @id @default(cuid())
  code   String         @unique // slug/código corto para URL personalizada
  status CheckoutStatus @default(CREATED)

  // Qué se va a comprar
  pack   Pack   @relation(fields: [packId], references: [id])
  packId String

  // Quién (opcional si es link público)
  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  // Preferencia/Payment asociado
  payment   Payment? @relation("PaymentToCheckout", fields: [paymentId], references: [id])
  paymentId String?  @unique // <- necesario para 1–1

  // Expiración opcional
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  // Redirecciones
  successUrl String?
  failureUrl String?
  pendingUrl String?

  // Tracking
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  @@index([status, expiresAt])
}

model WebhookLog {
  id          String          @id @default(cuid())
  provider    PaymentProvider
  eventType   String?
  deliveryId  String? // para idempotencia si el proveedor reintenta
  payload     Json
  receivedAt  DateTime        @default(now())
  processedOk Boolean         @default(false)
  error       String?

  @@index([provider, deliveryId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
