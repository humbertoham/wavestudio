# Placeholder keys only. Never commit real secrets.
# Production is already configured in Vercel; do not overwrite it from this file.
# UAT and dev must each use their own Vercel environment values and Neon database.

# Required server-only variables
# Must differ per environment. Never reuse production DATABASE_URL in uat or dev.
DATABASE_URL="<DATABASE_URL_FOR_THIS_ENVIRONMENT>"

# Local migration helpers. Put real values in .env.dev.local and .env.uat.local only.
# The branch scripts map these to DATABASE_URL without printing the secret value.
DATABASE_URL_DEV_BRANCH="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DATABASE_URL_UAT_BRANCH="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Current Prisma schema uses DATABASE_URL only. Keep a direct/unpooled Neon URL
# available per environment if your migration workflow needs one.
DIRECT_URL="<DIRECT_OR_UNPOOLED_DATABASE_URL_FOR_THIS_ENVIRONMENT>"
DATABASE_URL_UNPOOLED="<DIRECT_OR_UNPOOLED_DATABASE_URL_FOR_THIS_ENVIRONMENT>"
DIRECT_URL_DEV_BRANCH="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DIRECT_URL_UAT_BRANCH="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Must differ per environment unless intentionally shared.
JWT_SECRET="<LONG_RANDOM_JWT_SECRET_FOR_THIS_ENVIRONMENT>"
CRON_SECRET="<LONG_RANDOM_CRON_SECRET_FOR_THIS_ENVIRONMENT>"

# Must match the deployed domain for each environment.
APP_BASE_URL="<HTTPS_APP_BASE_URL_FOR_THIS_ENVIRONMENT>"

# Service credentials. Use environment-specific/sandbox values where appropriate.
RESEND_API_KEY="<RESEND_API_KEY>"
MP_ACCESS_TOKEN="<MERCADO_PAGO_ACCESS_TOKEN>"
MP_WEBHOOK_SECRET="<MERCADO_PAGO_WEBHOOK_SECRET>"

# Optional server-only variables
# If either Upstash value is missing, the app falls back to in-memory rate limiting.
UPSTASH_REDIS_REST_URL="<UPSTASH_REDIS_REST_URL_OPTIONAL>"
UPSTASH_REDIS_REST_TOKEN="<UPSTASH_REDIS_REST_TOKEN_OPTIONAL>"

# Use "1" only for local/dev Mercado Pago sandbox testing.
ALLOW_SANDBOX="0"

# Local dev helper only.
CLEAN_NEXT_FULL="0"

# No NEXT_PUBLIC variables are currently required.
